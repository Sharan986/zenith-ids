# Supabase Configuration
# Get these from: Supabase Dashboard -> Settings -> API

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase anon/public key (starts with eyJ...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key — NEVER expose this to the browser
# Used by server-side API routes that need to bypass Row Level Security
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# PhonePe Payment Gateway
# Get these from PhonePe Merchant Dashboard -> API Keys
PHONEPE_MERCHANT_ID=your-merchant-id
PHONEPE_SALT_KEY=your-salt-key
PHONEPE_SALT_INDEX=1
# Use UAT URL for testing, production URL for live:
# UAT:  https://api-preprod.phonepe.com/apis/pg-sandbox
# PROD: https://api.phonepe.com/apis/hermes
PHONEPE_API_URL=https://api-preprod.phonepe.com/apis/pg-sandbox

# Your application's public URL (used for PhonePe redirect/callback URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
